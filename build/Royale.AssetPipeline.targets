<Project>

  <PropertyGroup>
    <RoyaleRepositoryRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)..'))</RoyaleRepositoryRoot>
    <RoyaleAssetSourceRoot>$(RoyaleRepositoryRoot)assets</RoyaleAssetSourceRoot>
    <RoyaleAssetManifest>$(RoyaleAssetSourceRoot)/model-assets.json</RoyaleAssetManifest>
    <RoyaleAssetIntermediate>$(BaseIntermediateOutputPath)$(Configuration)/$(TargetFramework)/royale-assets/$(RoyaleAssetAudience)</RoyaleAssetIntermediate>
    <RoyaleAssetPipelineAssembly>$(RoyaleRepositoryRoot)tools/Royale.AssetPipeline/bin/$(Configuration)/net10.0/Royale.AssetPipeline.dll</RoyaleAssetPipelineAssembly>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(RoyaleRepositoryRoot)tools/Royale.AssetPipeline/Royale.AssetPipeline.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false" />
    <RoyaleAssetInput Include="$(RoyaleAssetManifest)" />
    <RoyaleAssetInput Include="$(RoyaleAssetSourceRoot)/meshes/**/*" />
  </ItemGroup>

  <Target Name="GenerateRoyaleAssets"
          BeforeTargets="CopyFilesToOutputDirectory"
          DependsOnTargets="ResolveProjectReferences"
          Inputs="@(RoyaleAssetInput)"
          Outputs="$(RoyaleAssetIntermediate)/.stamp">
    <Exec Command="dotnet &quot;$(RoyaleAssetPipelineAssembly)&quot; --manifest &quot;$(RoyaleAssetManifest)&quot; --source-root &quot;$(RoyaleAssetSourceRoot)&quot; --output &quot;$(RoyaleAssetIntermediate)&quot; --audience $(RoyaleAssetAudience)" />
    <Touch Files="$(RoyaleAssetIntermediate)/.stamp" AlwaysCreate="true" />
  </Target>

  <Target Name="CopyRoyaleAssetsToOutput"
          BeforeTargets="CopyFilesToOutputDirectory"
          DependsOnTargets="GenerateRoyaleAssets">
    <ItemGroup>
      <_RoyaleGeneratedAsset Include="$(RoyaleAssetIntermediate)/**/*"
                             Exclude="$(RoyaleAssetIntermediate)/.stamp" />
    </ItemGroup>
    <RemoveDir Directories="$(OutDir)assets" />
    <Copy SourceFiles="@(_RoyaleGeneratedAsset)"
          DestinationFiles="@(_RoyaleGeneratedAsset->'$(OutDir)assets/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="IncludeRoyaleAssetsInPublish"
          AfterTargets="ComputeFilesToPublish"
          DependsOnTargets="GenerateRoyaleAssets">
    <ItemGroup>
      <_RoyalePublishAsset Include="$(RoyaleAssetIntermediate)/**/*"
                           Exclude="$(RoyaleAssetIntermediate)/.stamp" />
      <ResolvedFileToPublish Include="@(_RoyalePublishAsset)">
        <RelativePath>assets/%(RecursiveDir)%(Filename)%(Extension)</RelativePath>
        <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      </ResolvedFileToPublish>
    </ItemGroup>
  </Target>

</Project>
